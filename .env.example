# Copy this to .env and fill in your values

# Required
GROQ_API_KEY=your_groq_api_key_here

# Optional — defaults shown
ENV_URL=http://localhost:7860
REDIS_URL=redis://localhost:6379
MODEL_NAME=llama-3.3-70b-versatile

# GitHub integration (v2) — required for ingester, PR opener, and webhook receiver
# Create a PAT at https://github.com/settings/tokens with 'repo' scope
GITHUB_TOKEN=your_github_pat_here

# GitHub App webhook — generate when creating the GitHub App
WEBHOOK_SECRET=your_github_webhook_secret_here

# v2 behaviour controls
AUTOPATCH_BASE_BRANCH=main
MIN_SCORE_TO_OPEN_PR=0.5
MAX_FILES_TO_PATCH=3
PYTEST_TIMEOUT=60
